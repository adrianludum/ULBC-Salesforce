    <fieldPermissions>
        <field>ULBC_Email_Send_Recipient__c.ULBC_First_Open_At__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ULBC_Email_Send_Recipient__c.ULBC_Open_Count__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ULBC_Email_Send_Recipient__c.ULBC_First_Click_At__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ULBC_Email_Send_Recipient__c.ULBC_Click_Count__c</field>
        <readable>true</readable>
