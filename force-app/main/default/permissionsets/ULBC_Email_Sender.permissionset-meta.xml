    </fieldPermissions>
    <fieldPermissions>
        <field>ULBC_Email_Event__c.ULBC_Occurred_At__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ULBC_Email_Event__c.ULBC_Aggregated__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>

    <!-- Apex class access -->
    <classAccesses>
        <apexClass>ULBC_EmailSendController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>ULBC_EmailSendService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>ULBC_EmailRecipientResolver</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>ULBC_EmailHtmlMutator</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>ULBC_EmailTokenService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
</PermissionSet>
