<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>ULBC Email Sender</label>
    <description>Compose and queue mass emails. Read-only for tracking events. Assign to staff who run newsletters or fundraising-dinner comms.</description>
    <hasActivationRequired>false</hasActivationRequired>

    <!-- Object permissions: Email Send (full CRUD on the parent) -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>ULBC_Email_Send__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <!-- Recipients: read + create (the service inserts these); no delete -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>ULBC_Email_Send_Recipient__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <!-- Events: read-only forensic log -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>ULBC_Email_Event__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <!-- Send: every field readable, key fields editable -->
    <fieldPermissions>
        <field>ULBC_Email_Send__c.ULBC_Campaign__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ULBC_Email_Send__c.ULBC_Email_Template_DevName__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ULBC_Email_Send__c.ULBC_Subject__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ULBC_Email_Send__c.ULBC_Status__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ULBC_Email_Send__c.ULBC_Recipient_Count__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ULBC_Email_Send__c.ULBC_Sent_Count__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ULBC_Email_Send__c.ULBC_Open_Count__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ULBC_Email_Send__c.ULBC_Click_Count__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ULBC_Email_Send__c.ULBC_Open_Rate__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ULBC_Email_Send__c.ULBC_Click_Rate__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ULBC_Email_Send__c.ULBC_Filter_Snapshot__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ULBC_Email_Send__c.ULBC_Initiated_By__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ULBC_Email_Send__c.ULBC_Sent_At__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>

    <!-- Recipient: read + create-time fields editable -->
    <fieldPermissions>
        <field>ULBC_Email_Send_Recipient__c.ULBC_Contact__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ULBC_Email_Send_Recipient__c.ULBC_Trust_ID__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ULBC_Email_Send_Recipient__c.ULBC_Email_Address__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ULBC_Email_Send_Recipient__c.ULBC_Token__c</field>
        <readable>true</readable>
