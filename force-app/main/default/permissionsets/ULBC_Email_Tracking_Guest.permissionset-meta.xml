<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>ULBC Email Tracking Guest</label>
    <description>Grants the ULBC Public Site Guest User the minimum permissions needed to record email opens, clicks, and unsubscribes. Assign to the Site Guest User profile via Setup → Sites → Public Access Settings.</description>
    <hasActivationRequired>false</hasActivationRequired>

    <!-- Email Event: Create + Read (Salesforce requires Read alongside Create; default OWD Private prevents cross-guest visibility) -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>ULBC_Email_Event__c</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Send: Read required because Recipient is master-detail child of Send.
         Salesforce enforces "to read child you must read parent." viewAllRecords
         off so cross-send visibility is governed by sharing rules. -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>ULBC_Email_Send__c</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Recipient: Read only. Salesforce's Guest User license forbids Edit
         and ViewAll on custom objects. The endpoint's `without sharing`
         Apex bypasses sharing rules to find recipients by token even when
         OWD is Private. Recipient.Unsubscribed_At is stamped asynchronously
         by ULBC_EmailEventAggregator (running as the scheduled user). -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>ULBC_Email_Send_Recipient__c</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Field-level permissions -->
    <fieldPermissions>
        <field>ULBC_Email_Event__c.ULBC_Recipient__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <!-- ULBC_Event_Type__c is required at the field level; Salesforce manages
         FLS implicitly and rejects explicit blocks. -->
    <fieldPermissions>
        <field>ULBC_Email_Event__c.ULBC_URL__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ULBC_Email_Event__c.ULBC_User_Agent__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ULBC_Email_Event__c.ULBC_IP_Hash__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <!-- ULBC_Occurred_At__c is required; FLS implicit. -->
    <fieldPermissions>
        <field>ULBC_Email_Event__c.ULBC_Aggregated__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>

    <fieldPermissions>
        <field>ULBC_Email_Send_Recipient__c.ULBC_Token__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ULBC_Email_Send_Recipient__c.ULBC_Contact__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <!-- ULBC_Unsubscribed_At__c: Guest no longer writes this directly;
         aggregator stamps it. Read-only here so dashboards/QA can verify. -->
    <fieldPermissions>
        <field>ULBC_Email_Send_Recipient__c.ULBC_Unsubscribed_At__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>

    <!-- The class itself -->
    <classAccesses>
        <apexClass>ULBC_EmailTrackingResource</apexClass>
        <enabled>true</enabled>
    </classAccesses>
</PermissionSet>
