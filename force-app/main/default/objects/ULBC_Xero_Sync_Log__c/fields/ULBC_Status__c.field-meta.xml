<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>ULBC_Status__c</fullName>
    <description>Outcome of the importer page run. Success = page committed cleanly. Partial = some rows committed, some failed (per-row errors in ULBC_Error_Message__c). Error = nothing committed (auth failure, rate limit, parse error).</description>
    <label>Status</label>
    <required>true</required>
    <trackTrending>false</trackTrending>
    <type>Picklist</type>
    <valueSet>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Success</fullName>
                <default>false</default>
                <label>Success</label>
            </value>
            <value>
                <fullName>Partial</fullName>
                <default>false</default>
                <label>Partial</label>
            </value>
            <value>
                <fullName>Error</fullName>
                <default>true</default>
                <label>Error</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
