<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>ULBC_Status__c</fullName>
    <description>Per-recipient outcome. Pending = materialised but not yet sent. Sent = SingleEmailMessage accepted. Bounced = post-send bounce notification (v2). Suppressed = excluded by resolver before send (opt-out, missing email, bounced previously). Failed = SingleEmailMessage threw an EmailException.</description>
    <label>Status</label>
    <required>true</required>
    <trackTrending>false</trackTrending>
    <type>Picklist</type>
    <valueSet>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Pending</fullName>
                <default>true</default>
                <label>Pending</label>
            </value>
            <value>
                <fullName>Sent</fullName>
                <default>false</default>
                <label>Sent</label>
            </value>
            <value>
                <fullName>Bounced</fullName>
                <default>false</default>
                <label>Bounced</label>
            </value>
            <value>
                <fullName>Suppressed</fullName>
                <default>false</default>
                <label>Suppressed</label>
            </value>
            <value>
                <fullName>Failed</fullName>
                <default>false</default>
                <label>Failed</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
